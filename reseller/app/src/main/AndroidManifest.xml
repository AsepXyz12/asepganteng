<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Dibutuhin biar tombol "Kamera" di file chooser upload (foto profil/
         post) bisa ambil foto/video langsung, bukan cuma pilih dari galeri -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Akses galeri foto/video (Android 13+ pakai izin granular ini,
         Android 12 ke bawah masih pakai READ_EXTERNAL_STORAGE) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- ===== Ditambahkan untuk fitur Alarm Jadwal Sholat ===== -->

    <!-- Android 13+ (API 33+) mewajibkan izin eksplisit ini sebelum app
         boleh nampilin notifikasi apapun -- tanpa ini, showNotification
         dari web/JS ATAU dari native bakal DIAM AJA gak muncul. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Lokasi GPS -- dipakai buat "mengunci" jadwal sholat ke daerah
         device yang pakai, BUKAN input kota manual. FINE = presisi GPS,
         COARSE = fallback jaringan seluler/wifi kalau GPS device mati. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Alarm presisi (native AlarmManager) supaya waktu adzan tetap
         berdering TEPAT WAKTU walau app sudah ditutup total / HP di-doze
         mode -- ini yang gak bisa dicapai cuma dari timer JS di web,
         karena semua JS berhenti total begitu proses app di-kill. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Biar alarm bisa "membangunkan" CPU dari sleep tepat pas jam
         sholat, dan device gak keburu masuk deep sleep sebelum notifikasi
         sempat tampil. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Supaya alarm tetap ke-set ulang otomatis setelah HP di-restart
         (kalau gak ada ini, alarm ilang tiap kali HP dinyalain ulang
         sampai user buka manual App-nya lagi). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Dibutuhin buat notifikasi full-screen (alarm "bangunin" layar
         terkunci) di Android 14+ (API 34+). -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- ========================================================= -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:theme="@style/Theme.AppRole"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== Komponen native Alarm Jadwal Sholat ===== -->

        <!-- Menerima "dering" dari AlarmManager tepat pas jam sholat,
             lalu nampilin notifikasi full-screen + suara, JALAN WALAU
             APP SUDAH DITUTUP TOTAL (bukan cuma di-minimize). -->
        <receiver
            android:name=".PrayerAlarmReceiver"
            android:exported="false" />

        <!-- Nge-set ulang semua alarm otomatis abis HP di-restart, biar
             gak perlu buka app manual dulu abis restart baru alarm balik
             aktif. -->
        <receiver
            android:name=".BootRestoreReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Activity full-screen yang muncul di ATAS layar terkunci pas
             alarm bunyi (kayak alarm bawaan HP) -- munculin tombol
             "Tandai Selesai" / "Tunda 5 menit". -->
        <activity
            android:name=".PrayerAlarmActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.AppRole" />

        <!-- ================================================ -->

    </application>

    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.media.action.VIDEO_CAPTURE" />
        </intent>
    </queries>

</manifest>
